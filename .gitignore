# Dependencies
node_modules/
*/node_modules/
backend/node_modules/
frontend/node_modules/

# Environment variables (NEVER commit real secrets)
.env
.env.local
.env.development.local
.env.test.local
backend/.env
frontend/.env
*/.env

# Build outputs
dist/
build/
backend/dist/
frontend/build/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Uploads (don't commit uploaded files)
backend/uploads/videos/*
backend/uploads/audio/*
backend/uploads/thumbnails/*
!backend/uploads/videos/.gitkeep
!backend/uploads/audio/.gitkeep
!backend/uploads/thumbnails/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
*.egg-info/
.pytest_cache/

# ML Models (don't commit large model files)
*.bin
*.pt
*.pth
*.onnx
*.h5
*.pkl
MachineLearning/*.pth
MachineLearning/*.bin

# Old documentation with secrets
New folder/
"New folder/"

# Testing
coverage/
.nyc_output/

# Misc
.cache/
.temp/
*.bak
*.tmp
